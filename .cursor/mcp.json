{
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--read-only",
        "--project-ref=YOUR_PROJECT_REF"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "YOUR_SUPABASE_PAT"
      }
    },
    "atlassian": {
      "url": "https://mcp.atlassian.com/v1/sse"
    },
    "vercel": {
      "url": "https://mcp.vercel.com"
    },
    "sentry": {
      "url": "https://mcp.sentry.dev/mcp"
    }
  }
}
