{
  "terminalAllowlist": [
    "npm test",
    "npm run typecheck",
    "npm run build",
    "npm run lint",
    "npm run dev",
    "npm install",
    "git status",
    "git diff",
    "git log",
    "git add",
    "git commit",
    "git push",
    "git pull",
    "gh pr create",
    "gh pr view"
  ],
  "mcpAllowlist": [
    "supabase:*",
    "atlassian:get*",
    "atlassian:search*",
    "sentry:get*"
  ],
  "autoRun": {
    "block_instructions": [
      "destructive git (reset, clean, force push, branch -D) or rewriting history",
      "reading or writing secrets, credentials, or any .env* file",
      "editing CI/workflow files under .github/",
      "running production database migrations",
      "modifying cloud infrastructure (aws, gcloud, terraform)",
      "making outbound network requests (curl, wget)"
    ]
  }
}
