{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "./.cursor/hooks/a11y-gate.sh"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "./.cursor/hooks/guard-shell.sh"
      }
    ],
    "preToolUse": [
      {
        "command": "node \".cursor/skills/impeccable/scripts/hook-before-edit.mjs\"",
        "timeout": 5
      }
    ]
  }
}
